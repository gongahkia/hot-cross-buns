// Copy these values into local Xcode build settings or pass them to xcodebuild.
// Do not commit real OAuth client IDs, reversed client IDs, or Maps keys.

GOOGLE_MACOS_CLIENT_ID = your-macos-oauth-client-id.apps.googleusercontent.com
GOOGLE_MACOS_REVERSED_CLIENT_ID = com.googleusercontent.apps.your-macos-reversed-client-id

// Optional. Google Maps Embed API key used by LocationFullView to render the
// expanded-map sheet via iframe. Create it at
// https://console.cloud.google.com/google/maps-apis/credentials and restrict
// it to the Maps Embed API + the macOS bundle ID (com.gongahkia.hotcrossbuns.mac).
// When absent, the app silently falls back to a MapKit view. Leaving the
// placeholder unchanged is equivalent to leaving the value empty — the
// GoogleMapsConfig reader rejects both.
GOOGLE_MAPS_EMBED_API_KEY = your-maps-embed-api-key
