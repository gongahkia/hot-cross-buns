<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Dev-only entitlements. Used for unsigned local builds via `make run` so the
  Keychain + network work without needing an Apple Developer team. Ships with
  sandbox DISABLED — do not distribute builds signed with this file. Release
  / DMG builds should point CODE_SIGN_ENTITLEMENTS back at HotCrossBuns.entitlements.
-->
<plist version="1.0">
<dict>
	<key>com.apple.security.network.client</key>
	<true/>
</dict>
</plist>
