        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Seret acara sedia ada untuk menjadualkannya semula sambil mengekalkan tempoh dan pengambilan 15 minit."
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "கால அளவு மற்றும் 15 நிமிட ஸ்னாப்பிங்கைப் பாதுகாக்கும் போது, ​​ஏற்கனவே உள்ள நிகழ்வை மீண்டும் திட்டமிட இழுக்கவும்."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
