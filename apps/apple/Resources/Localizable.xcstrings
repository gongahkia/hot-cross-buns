    "This build is missing a Google OAuth client ID. Follow the Google Cloud setup above, rebuild the app, then connect your account.": {
      "localizations": {
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Binaan ini tiada ID klien Google OAuth. Ikuti persediaan Google Cloud di atas, bina semula apl, kemudian sambungkan akaun anda."
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "இந்த உருவாக்கத்தில் Google OAuth கிளையன்ட் ஐடி இல்லை. மேலே உள்ள Google கிளவுட் அமைப்பைப் பின்பற்றி, பயன்பாட்டை மீண்டும் உருவாக்கவும், பின்னர் உங்கள் கணக்கை இணைக்கவும்."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "此版本缺少 Google OAuth 客户端 ID。按照上面的 Google Cloud 设置，重建应用，然后连接您的帐户。"
          }
        },
        "id": {
          "stringUnit": {
            "state": "new",
