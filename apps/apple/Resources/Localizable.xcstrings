    "Expands a start time into an end time when no explicit end is given.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Expands a start time into an end time when no explicit end is given."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Mengembangkan masa mula kepada masa tamat apabila tiada pengakhiran yang jelas diberikan."
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "வெளிப்படையான முடிவு எதுவும் வழங்கப்படாதபோது தொடக்க நேரத்தை இறுதி நேரமாக விரிவுபடுத்துகிறது."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "当没有给出明确的结束时，将开始时间扩展为结束时间。"
          }
        },
        "id": {
          "stringUnit": {
            "state": "new",
            "value": "Expands a start time into an end time when no explicit end is given."
          }
