    "Choose whether app chrome resolves as dark, light, or follows macOS.": {
      "localizations": {
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Pilih sama ada chrome apl diselesaikan sebagai gelap, terang atau mengikuti macOS."
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
