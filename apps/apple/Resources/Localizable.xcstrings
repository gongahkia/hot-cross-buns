    "Adding ⭐ to a task title shows as a real star emoji in Google Tasks everywhere.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Adding ⭐ to a task title shows as a real star emoji in Google Tasks everywhere."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Menambahkan ⭐ pada tajuk tugasan menunjukkan sebagai emoji bintang sebenar dalam Tugasan Google di mana-mana sahaja."
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "பணியின் தலைப்பில் ⭐ஐச் சேர்ப்பது, எல்லா இடங்களிலும் Google Tasks இல் உண்மையான நட்சத்திர ஈமோஜியாகக் காண்பிக்கப்படும்."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
