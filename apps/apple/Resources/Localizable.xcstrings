    "Understands single times, ranges, and keyword anchors like noon or midnight.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Understands single times, ranges, and keyword anchors like noon or midnight."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Memahami masa tunggal, julat dan sauh kata kunci seperti tengah hari atau tengah malam."
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "மதியம் அல்லது நள்ளிரவு போன்ற ஒற்றை நேரங்கள், வரம்புகள் மற்றும் முக்கிய வார்த்தை அறிவிப்பாளர்களைப் புரிந்துகொள்கிறது."
          }
        },
        "zh-Hans": {
