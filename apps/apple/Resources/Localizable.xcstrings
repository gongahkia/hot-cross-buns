    "Leave empty for a one-off event. The \"RRULE:\" prefix is added automatically if missing.": {
      "localizations": {
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Biarkan kosong untuk acara sekali sahaja. Awalan \"RRULE:\" ditambah secara automatik jika tiada."
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "ஒருமுறை நடக்கும் நிகழ்வுக்கு காலியாக விடவும். \"RRULE:\" முன்னொட்டு விடுபட்டால் தானாகவே சேர்க்கப்படும்."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "为一次性事件留空。如果缺少“RRULE:”前缀，则会自动添加。"
          }
        },
