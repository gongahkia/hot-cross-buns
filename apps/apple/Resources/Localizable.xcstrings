    "Runs commands and searches tasks, notes, events, lists, calendars, and saved filters.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Runs commands and searches tasks, notes, events, lists, calendars, and saved filters."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Menjalankan arahan dan mencari tugas, nota, acara, senarai, kalendar dan penapis yang disimpan."
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "கட்டளைகளை இயக்குகிறது மற்றும் பணிகள், குறிப்புகள், நிகழ்வுகள், பட்டியல்கள், காலெண்டர்கள் மற்றும் சேமித்த வடிப்பான்களைத் தேடுகிறது."
          }
        },
        "zh-Hans": {
          "stringUnit": {
