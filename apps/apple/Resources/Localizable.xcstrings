    "Appears as a section in the menu-bar popover with a match count and a short preview.": {
      "localizations": {
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Muncul sebagai bahagian dalam popover bar menu dengan kiraan padanan dan pratonton pendek."
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "மேட்ச் எண்ணிக்கை மற்றும் குறுகிய முன்னோட்டத்துடன் மெனு-பார் பாப்ஓவரில் ஒரு பிரிவாகத் தோன்றும்."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "显示为菜单栏弹出窗口中的一个部分，其中包含匹配计数和简短预览。"
          }
        }
      }
    },
    "Applies to %@ task%@. A %@ tag per task is silently skipped by the optimizer.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "Applies to %1$@ task%2$@. A %3$@ tag per task is silently skipped by the optimizer."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Berlaku untuk %1$@ tugas%2$@. Teg %3$@ setiap tugasan dilangkau secara senyap oleh pengoptimum."
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ task%2$@க்கு பொருந்தும். ஒரு பணிக்கு %3$@ டேக் ஆப்டிமைசரால் அமைதியாக தவிர்க்கப்பட்டது."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "适用于 %1$@ 任务 %2$@。优化器会默默地跳过每个任务的 %3$@ 标记。"
          }
        }
      }
    },
