    "Sign-in disabled? This build is missing Google sign-in credentials. Install an official release or use a configured local build.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Sign-in disabled? This build is missing Google sign-in credentials. Install an official release or use a configured local build."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Log masuk dilumpuhkan? Binaan ini tiada bukti kelayakan log masuk Google. Pasang keluaran rasmi atau gunakan binaan tempatan yang dikonfigurasikan."
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "உள்நுழைவு முடக்கப்பட்டதா? இந்தக் கட்டமைப்பில் Google உள்நுழைவுச் சான்றுகள் இல்லை. அதிகாரப்பூர்வ வெளியீட்டை நிறுவவும் அல்லது உள்ளமைக்கப்பட்ட உள்ளூர் கட்டமைப்பைப் பயன்படுத்தவும்."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "登录已禁用？此版本缺少 Google 登录凭据。安装官方版本或使用配置的本地版本。"
          }
        },
        "id": {
          "stringUnit": {
            "state": "new",
            "value": "Sign-in disabled? This build is missing Google sign-in credentials. Install an official release or use a configured local build."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "new",
            "value": "Sign-in disabled? This build is missing Google sign-in credentials. Install an official release or use a configured local build."
          }
        },
