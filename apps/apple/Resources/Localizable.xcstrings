    "Custom": {
      "localizations": {
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Adat"
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "தனிப்பயன்"
          }
        },
        "zh-Hans": {
