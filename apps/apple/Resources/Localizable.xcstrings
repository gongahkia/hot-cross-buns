    "All reminders within the next %@ days are scheduled.": {
      "localizations": {
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Semua peringatan dalam %@ hari berikutnya dijadualkan."
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "அடுத்த %@ நாட்களுக்குள் அனைத்து நினைவூட்டல்களும் திட்டமிடப்பட்டுள்ளன."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "未来 %@ 天内的所有提醒均已安排。"
          }
        }
