    "Click a shortcut and press the new key combo. Escape cancels. Modifier keys (⌘⇧⌥⌃) are required except for function keys and arrows.": {
      "localizations": {
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Klik pintasan dan tekan kombo kekunci baharu. Melarikan diri dibatalkan. Kekunci pengubah suai (⌘⇧⌥⌃) diperlukan kecuali kekunci fungsi dan anak panah."
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "ஷார்ட்கட்டைக் கிளிக் செய்து புதிய கீ காம்போவை அழுத்தவும். எஸ்கேப் கேன்சல். செயல்பாட்டு விசைகள் மற்றும் அம்புக்குறிகளைத் தவிர, மாற்றி விசைகள் (⌘⇧⌥⌃) தேவை."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "单击快捷方式并按新的组合键。逃脱取消。除功能键和箭头外，还需要修饰键 (⌘⇧⌥⌃)。"
          }
        },
        "id": {
          "stringUnit": {
            "state": "new",
            "value": "Click a shortcut and press the new key combo. Escape cancels. Modifier keys (⌘⇧⌥⌃) are required except for function keys and arrows."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "new",
            "value": "Click a shortcut and press the new key combo. Escape cancels. Modifier keys (⌘⇧⌥⌃) are required except for function keys and arrows."
