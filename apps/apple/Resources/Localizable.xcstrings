    "The toolbar filter menu switches between All / Overdue / Today / Next 7 / No Date / Notes / Stale Lists / saved custom filters.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The toolbar filter menu switches between All / Overdue / Today / Next 7 / No Date / Notes / Stale Lists / saved custom filters."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Menu penapis bar alat bertukar antara Semua / Tertunggak / Hari Ini / 7 Seterusnya / Tiada Tarikh / Nota / Senarai Lapuk / penapis tersuai yang disimpan."
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "கருவிப்பட்டி வடிகட்டி மெனு அனைத்தும் / காலாவதி / இன்று / அடுத்த 7 / தேதி இல்லை / குறிப்புகள் / பழைய பட்டியல்கள் / சேமிக்கப்பட்ட தனிப்பயன் வடிப்பான்களுக்கு இடையே மாறுகிறது."
          }
