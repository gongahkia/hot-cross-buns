    "This is a local review surface only. It uses the existing duplicate index and dismissal rules; it does not change how tasks sync or mutate.": {
      "localizations": {
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Ini adalah permukaan ulasan tempatan sahaja. Ia menggunakan indeks pendua sedia ada dan peraturan pemecatan; ia tidak mengubah cara tugasan menyegerak atau bermutasi."
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "இது உள்ளூர் மதிப்பாய்வு மேற்பரப்பு மட்டுமே. இது ஏற்கனவே உள்ள நகல் குறியீடு மற்றும் பணிநீக்கம் விதிகளைப் பயன்படுத்துகிறது; பணிகள் எவ்வாறு ஒத்திசைக்கப்படுகின்றன அல்லது மாற்றப்படுகின்றன என்பதை இது மாற்றாது."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "这只是本地评论表面。它使用现有的重复索引和剔除规则；它不会改变任务同步或变异的方式。"
          }
        },
        "id": {
          "stringUnit": {
            "state": "new",
            "value": "This is a local review surface only. It uses the existing duplicate index and dismissal rules; it does not change how tasks sync or mutate."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "new",
            "value": "This is a local review surface only. It uses the existing duplicate index and dismissal rules; it does not change how tasks sync or mutate."
          }
        },
        "th": {
