          }
        }
      }
    },
    "This event is part of a recurring series. \"Every event in the series\" deletes past occurrences too — not just upcoming. No guest updates are sent.": {
      "localizations": {
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Acara ini adalah sebahagian daripada siri berulang. \"Setiap peristiwa dalam siri\" juga memadamkan kejadian lalu — bukan hanya akan datang. Tiada kemas kini tetamu dihantar."
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "இந்த நிகழ்வு தொடர்ச்சியான தொடரின் ஒரு பகுதியாகும். \"தொடரில் உள்ள ஒவ்வொரு நிகழ்வும்\" கடந்த கால நிகழ்வுகளையும் நீக்குகிறது - வரவிருக்கும் நிகழ்வுகள் மட்டுமல்ல. விருந்தினர் அறிவிப்புகள் எதுவும் அனுப்பப்படவில்லை."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "该活动是重复系列活动的一部分。 “系列中的每个事件”也会删除过去发生的事件，而不仅仅是即将发生的事件。不发送任何访客更新。"
          }
        },
        "id": {
          "stringUnit": {
            "state": "new",
            "value": "This event is part of a recurring series. \"Every event in the series\" deletes past occurrences too — not just upcoming. No guest updates are sent."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "new",
            "value": "This event is part of a recurring series. \"Every event in the series\" deletes past occurrences too — not just upcoming. No guest updates are sent."
          }
        },
        "th": {
          "stringUnit": {
            "state": "new",
            "value": "This event is part of a recurring series. \"Every event in the series\" deletes past occurrences too — not just upcoming. No guest updates are sent."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "new",
            "value": "This event is part of a recurring series. \"Every event in the series\" deletes past occurrences too — not just upcoming. No guest updates are sent."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "new",
            "value": "This event is part of a recurring series. \"Every event in the series\" deletes past occurrences too — not just upcoming. No guest updates are sent."
          }
        },
        "zh-Hant": {
          "stringUnit": {
