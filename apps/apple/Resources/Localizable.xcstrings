    "There's no separate backend. OAuth tokens stay in the Keychain. Disconnect in Settings to wipe local state.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "There's no separate backend. OAuth tokens stay in the Keychain. Disconnect in Settings to wipe local state."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Tiada bahagian belakang yang berasingan. Token OAuth kekal dalam Rantai Kunci. Putuskan sambungan dalam Tetapan untuk memadam keadaan setempat."
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "தனி பின்தளம் இல்லை. OAuth டோக்கன்கள் கீசெயினில் இருக்கும். உள்ளூர் நிலையை அழிக்க, அமைப்புகளில் இணைப்பைத் துண்டிக்கவும்."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "没有单独的后端。 OAuth 令牌保留在钥匙串中。在“设置”中断开连接以擦除本地状态。"
          }
        },
        "id": {
          "stringUnit": {
            "state": "new",
            "value": "There's no separate backend. OAuth tokens stay in the Keychain. Disconnect in Settings to wipe local state."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "new",
            "value": "There's no separate backend. OAuth tokens stay in the Keychain. Disconnect in Settings to wipe local state."
          }
        },
        "th": {
          "stringUnit": {
            "state": "new",
            "value": "There's no separate backend. OAuth tokens stay in the Keychain. Disconnect in Settings to wipe local state."
          }
        },
        "ja": {
