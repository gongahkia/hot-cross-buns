    "Deleting an event with other attendees may remove it from their calendars and send cancellations. Proceed carefully.": {
      "localizations": {
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Memadamkan acara dengan peserta lain boleh mengalih keluar acara itu daripada kalendar mereka dan menghantar pembatalan. Teruskan dengan berhati-hati."
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "மற்ற பங்கேற்பாளர்களுடன் ஒரு நிகழ்வை நீக்குவது அவர்களின் காலெண்டர்களில் இருந்து அதை அகற்றி, ரத்துசெய்தல்களை அனுப்பலாம். கவனமாக தொடரவும்."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "删除与其他参与者一起的活动可能会将其从他们的日历中删除并发送取消通知。小心行事。"
          }
        },
        "id": {
          "stringUnit": {
            "state": "new",
            "value": "Deleting an event with other attendees may remove it from their calendars and send cancellations. Proceed carefully."
          }
        },
