    "Each tab can hide lists independently of the global Task Lists selection. Turn off \"Use custom filter\" to fall back to the global set.": {
      "localizations": {
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Setiap tab boleh menyembunyikan senarai secara bebas daripada pemilihan Senarai Tugas global. Matikan \"Gunakan penapis tersuai\" untuk kembali ke set global."
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "ஒவ்வொரு தாவலும் உலகளாவிய பணிப் பட்டியல்களின் தேர்விலிருந்து சுயாதீனமாக பட்டியல்களை மறைக்க முடியும். உலகளாவிய தொகுப்பிற்குத் திரும்ப \"தனிப்பயன் வடிகட்டியைப் பயன்படுத்து\" என்பதை முடக்கவும்."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "每个选项卡都可以独立于全局任务列表选择来隐藏列表。关闭“使用自定义过滤器”以回退到全局设置。"
          }
        },
        "id": {
          "stringUnit": {
            "state": "new",
            "value": "Each tab can hide lists independently of the global Task Lists selection. Turn off \"Use custom filter\" to fall back to the global set."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "new",
            "value": "Each tab can hide lists independently of the global Task Lists selection. Turn off \"Use custom filter\" to fall back to the global set."
