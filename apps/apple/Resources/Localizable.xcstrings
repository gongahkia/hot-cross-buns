    "Visibility rules are local. Deletion modes issue Google API deletes — events go to Google Calendar's 30-day web trash, tasks are tombstoned and not user-recoverable.": {
      "localizations": {
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Peraturan keterlihatan adalah setempat. Mod pemadaman mengeluarkan pemadaman API Google — acara pergi ke sampah web 30 hari Kalendar Google, tugasan dilemparkan dengan batu nisan dan tidak boleh dipulihkan pengguna."
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "தெரிவுநிலை விதிகள் உள்ளூர். நீக்குதல் முறைகள் Google API நீக்குகிறது - நிகழ்வுகள் Google Calendar இன் 30-நாள் வலை குப்பைக்கு செல்கின்றன, பணிகள் கல்லறையாக இருக்கும் மற்றும் பயனரால் மீட்டெடுக்க முடியாது."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "可见性规则是本地的。删除模式会导致 Google API 删除 - 事件会进入 Google 日历的 30 天网络垃圾箱，任务会被逻辑删除且用户无法恢复。"
          }
        },
        "id": {
          "stringUnit": {
            "state": "new",
            "value": "Visibility rules are local. Deletion modes issue Google API deletes — events go to Google Calendar's 30-day web trash, tasks are tombstoned and not user-recoverable."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "new",
            "value": "Visibility rules are local. Deletion modes issue Google API deletes — events go to Google Calendar's 30-day web trash, tasks are tombstoned and not user-recoverable."
          }
        },
        "th": {
          "stringUnit": {
            "state": "new",
            "value": "Visibility rules are local. Deletion modes issue Google API deletes — events go to Google Calendar's 30-day web trash, tasks are tombstoned and not user-recoverable."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "new",
            "value": "Visibility rules are local. Deletion modes issue Google API deletes — events go to Google Calendar's 30-day web trash, tasks are tombstoned and not user-recoverable."
          }
        },
        "ko": {
