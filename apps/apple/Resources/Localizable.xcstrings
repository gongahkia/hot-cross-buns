            "value": "இல்லை"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "没有任何"
          }
        }
      }
    },
    "Notes include location: %@": {
      "localizations": {
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Nota termasuk lokasi: %@"
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "குறிப்புகளில் இடம் அடங்கும்: %@"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "注释包括位置：%@"
          }
        }
      }
    },
    "Notes: %@": {
      "localizations": {
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Nota: %@"
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "குறிப்புகள்: %@"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "注释：%@"
          }
        }
      }
    },
    "Nothing currently matches the rules — enabling this won't delete anything today, but future items will be cleaned up as they age past the threshold.": {
      "localizations": {
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Tiada apa-apa yang sepadan dengan peraturan pada masa ini — mendayakan ini tidak akan memadamkan apa-apa hari ini, tetapi item akan datang akan dibersihkan apabila umurnya melepasi ambang."
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "தற்போது விதிகளுடன் எதுவும் பொருந்தவில்லை - இதை இயக்குவது இன்று எதையும் நீக்காது, ஆனால் எதிர்கால உருப்படிகள் வாசலைக் கடந்தவுடன் அவை சுத்தம் செய்யப்படும்."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "当前没有任何内容符合规则 - 启用此功能不会删除今天的任何内容，但未来的项目将在超过阈值时被清除。"
          }
        }
      }
    },
    "Nothing matches \"%@\"": {
      "localizations": {
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Tiada apa yang sepadan dengan \"%@\""
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "\"%@\" உடன் எதுவும் பொருந்தவில்லை"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "没有任何内容与“%@”匹配"
          }
        }
      }
    },
    "Nothing scheduled for this day.": {
      "localizations": {
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Tiada apa-apa yang dijadualkan untuk hari ini."
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "இந்த நாளில் எதுவும் திட்டமிடப்படவில்லை."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "这一天没什么安排。"
          }
        }
      }
    },
    "Nothing scheduled in the next %@ days.": {
      "localizations": {
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Tiada apa-apa yang dijadualkan dalam %@ hari seterusnya."
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "அடுத்த %@ நாட்களில் எதுவும் திட்டமிடப்படவில்லை."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "接下来的 %@ 天内没有任何安排。"
          }
        }
      }
    },
    "Off by default to avoid accidental emails. Turn on only when you want guests to get a notification for this change.": {
      "localizations": {
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Matikan secara lalai untuk mengelakkan e-mel yang tidak disengajakan. Hidupkan hanya apabila anda mahu tetamu mendapat pemberitahuan untuk perubahan ini."
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "தற்செயலான மின்னஞ்சல்களைத் தவிர்க்க, இயல்புநிலையாக முடக்கவும். இந்த மாற்றத்திற்கான அறிவிப்பை விருந்தினர்கள் பெற வேண்டும் என நீங்கள் விரும்பினால் மட்டும் இயக்கவும்."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "默认关闭以避免意外发送电子邮件。仅当您希望访客收到此更改的通知时才打开。"
          }
        }
      }
    },
    "Off: the popover starts compact and hides optional fields behind \"More\". On: the popover opens detailed — matches Apple Calendar's inline expansion.": {
      "localizations": {
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Mati: popover mula padat dan menyembunyikan medan pilihan di belakang \"Lagi\". Hidupkan: popover dibuka secara terperinci — sepadan dengan pengembangan sebaris Kalendar Apple."
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "ஆஃப்: பாப்ஓவர் கச்சிதமாகத் தொடங்கி, \"மேலும்\" என்பதற்குப் பின்னால் விருப்பப் புலங்களை மறைக்கிறது. ஆன்: பாப்ஓவர் விரிவாகத் திறக்கிறது — Apple Calendar இன் இன்லைன் விரிவாக்கத்துடன் பொருந்துகிறது."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "关闭：弹出窗口开始紧凑，并将可选字段隐藏在“更多”后面。开：弹出窗口详细打开 — 与 Apple 日历的内联扩展相匹配。"
          }
        }
      }
    },
    "Older events are dropped from the local cache to keep memory + disk tight. Drops never touch Google — a Force Resync refetches everything.": {
      "localizations": {
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Peristiwa lama digugurkan daripada cache setempat untuk memastikan memori + cakera padat. Drops tidak pernah menyentuh Google — Force Resync menyemak semula segala-galanya."
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "நினைவகம் + வட்டை இறுக்கமாக வைத்திருக்க பழைய நிகழ்வுகள் உள்ளூர் தற்காலிக சேமிப்பிலிருந்து கைவிடப்படும். துளிகள் Google ஐத் தொடாது - ஒரு Force Resync எல்லாவற்றையும் திரும்பப் பெறுகிறது."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "较旧的事件将从本地缓存中删除，以保持内存和磁盘紧张。 Drops 永远不会触及 Google — 强制重新同步会重新获取所有内容。"
          }
        }
      }
    },
    "Older events are dropped from the local cache to keep memory + disk tight. Drops never touch Google — a Force Resync refetches everything. Recently-edited events (within the window) are preserved even if they ended earlier. Past-event cleanup on Google is a separate setting under \"Past cleanup\".": {
      "localizations": {
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Peristiwa lama digugurkan daripada cache setempat untuk memastikan memori + cakera padat. Drops tidak pernah menyentuh Google — Force Resync menyemak semula segala-galanya. Acara yang disunting baru-baru ini (dalam tetingkap) dikekalkan walaupun ia berakhir lebih awal. Pembersihan peristiwa lalu di Google ialah tetapan berasingan di bawah \"Pembersihan lalu\"."
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "நினைவகம் + வட்டை இறுக்கமாக வைத்திருக்க பழைய நிகழ்வுகள் உள்ளூர் தற்காலிக சேமிப்பிலிருந்து கைவிடப்படும். துளிகள் Google ஐத் தொடாது - ஒரு Force Resync எல்லாவற்றையும் திரும்பப் பெறுகிறது. சமீபத்தில் திருத்தப்பட்ட நிகழ்வுகள் (சாளரத்திற்குள்) முன்பே முடிந்தாலும் அவை பாதுகாக்கப்படும். Google இல் கடந்தகால நிகழ்வுகளை சுத்தம் செய்வது என்பது \"பாஸ்ட் கிளீனப்\" என்பதன் கீழ் ஒரு தனி அமைப்பாகும்."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "较旧的事件将从本地缓存中删除，以保持内存和磁盘紧张。 Drops 永远不会触及 Google — 强制重新同步会重新获取所有内容。最近编辑的事件（在窗口内）即使较早结束，也会被保留。 Google 上的过去事件清理是“过去清理”下的一个单独设置。"
          }
        }
      }
    },
    "On Date": {
      "localizations": {
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Pada Tarikh"
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "தேதியில்"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "日期"
          }
        }
      }
    },
    "Opening Google Sign-In…": {
      "localizations": {
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Membuka Log Masuk Google…"
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "Google உள்நுழைவைத் திறக்கிறது…"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "打开 Google 登录..."
          }
        }
      }
    },
    "Options": {
      "localizations": {
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Pilihan"
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "விருப்பங்கள்"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "选项"
          }
        }
      }
    },
    "Override the global font + size for specific surfaces. Settings persist locally and never touch Google data. Unset surfaces inherit the global Appearance values above.": {
      "localizations": {
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Gantikan fon global + saiz untuk permukaan tertentu. Tetapan berterusan secara setempat dan jangan sekali-kali menyentuh data Google. Permukaan yang tidak ditetapkan mewarisi nilai Rupa global di atas."
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "குறிப்பிட்ட மேற்பரப்புகளுக்கான உலகளாவிய எழுத்துரு + அளவை மேலெழுதவும். அமைப்புகள் உள்ளூரில் தொடர்ந்து இருக்கும் மற்றும் Google தரவைத் தொடவே இல்லை. அமைக்கப்படாத மேற்பரப்புகள் மேலே உள்ள உலகளாவிய தோற்ற மதிப்புகளைப் பெறுகின்றன."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "覆盖特定表面的全局字体+大小。设置保留在本地，并且永远不会触及 Google 数据。未设置的曲面继承上面的全局外观值。"
          }
        }
      }
    },
    "Pick a task from the list to view and edit its details.": {
      "localizations": {
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Pilih tugas daripada senarai untuk melihat dan mengedit butirannya."
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "பட்டியலிலிருந்து ஒரு பணியைத் தேர்ந்தெடுத்து அதன் விவரங்களைப் பார்க்கவும் திருத்தவும்."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "从列表中选择一个任务以查看和编辑其详细信息。"
          }
        }
      }
    },
    "Pick at least one calendar in Settings → Calendars to see events here.": {
      "localizations": {
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Pilih sekurang-kurangnya satu kalendar dalam Tetapan → Kalendar untuk melihat acara di sini."
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "இங்கே நிகழ்வுகளைப் பார்க்க, அமைப்புகள் → கேலெண்டர்களில் குறைந்தது ஒரு காலெண்டரையாவது தேர்ந்தெடுக்கவும்."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在“设置”→“日历”中至少选择一个日历以在此处查看事件。"
          }
        }
      }
    },
    "Pinned filters": {
      "localizations": {
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Penapis disematkan"
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "பின் செய்யப்பட்ட வடிப்பான்கள்"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "固定过滤器"
          }
        }
      }
    },
    "Potential duplicate tasks will appear here when exact title-and-notes matches are found.": {
      "localizations": {
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Tugas pendua yang berpotensi akan muncul di sini apabila padanan tajuk dan nota yang tepat ditemui."
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "சரியான தலைப்பு மற்றும் குறிப்புகள் பொருத்தங்கள் கண்டறியப்படும் போது சாத்தியமான நகல் பணிகள் இங்கே தோன்றும்."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "当找到精确的标题和注释匹配时，潜在的重复任务将出现在此处。"
          }
        }
      }
    },
    "Press keys…": {
      "localizations": {
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Tekan kekunci…"
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "விசைகளை அழுத்தவும்…"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "按键..."
          }
        }
      }
    },
