    "Preview DMGs do not auto-update in place. Install newer builds from the GitHub Releases page when one is published.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Preview DMGs do not auto-update in place. Install newer builds from the GitHub Releases page when one is published."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Pratonton DMG tidak dikemas kini secara automatik di tempatnya. Pasang binaan yang lebih baharu daripada halaman Keluaran GitHub apabila ia diterbitkan."
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "முன்னோட்டம் DMGகள் தானாக புதுப்பிக்கப்படாது. கிட்ஹப் வெளியீடுகள் பக்கத்திலிருந்து புதிய உருவாக்கங்களை நிறுவவும்."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "预览 DMG 不会就地自动更新。发布版本后，从 GitHub 版本页面安装较新的版本。"
          }
        },
        "id": {
          "stringUnit": {
            "state": "new",
            "value": "Preview DMGs do not auto-update in place. Install newer builds from the GitHub Releases page when one is published."
          }
        },
