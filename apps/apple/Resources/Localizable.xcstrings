    "macOS denied access to the Keychain. Unlock it (Applications → Utilities → Keychain Access → log in) then Reconnect Google.": {
      "localizations": {
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "macOS menafikan akses kepada Rantai Kunci. Buka kuncinya (Aplikasi → Utiliti → Akses Rantai Kunci → log masuk) kemudian sambung semula Google."
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "மேகோஸ் கீசெயினுக்கான அணுகலை மறுத்தது. அதைத் திறக்கவும் (பயன்பாடுகள் → பயன்பாடுகள் → கீசெயின் அணுகல் → உள்நுழைக) பின்னர் Google ஐ மீண்டும் இணைக்கவும்."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "macOS 拒绝访问钥匙串。解锁它（应用程序 → 实用程序 → 钥匙串访问 → 登录），然后重新连接 Google。"
          }
        },
        "id": {
          "stringUnit": {
            "state": "new",
            "value": "macOS denied access to the Keychain. Unlock it (Applications → Utilities → Keychain Access → log in) then Reconnect Google."
          }
        },
        "vi": {
