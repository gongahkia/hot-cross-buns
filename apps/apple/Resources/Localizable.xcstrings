    "Travel Time and attachments sync through google.com but aren't exposed through the Google Calendar API — add them from the web UI after creating.": {
      "localizations": {
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Masa Perjalanan dan lampiran disegerakkan melalui google.com tetapi tidak didedahkan melalui API Kalendar Google — tambahkannya daripada UI web selepas membuat."
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "பயண நேரம் மற்றும் இணைப்புகள் google.com மூலம் ஒத்திசைக்கப்படுகின்றன, ஆனால் அவை Google Calendar API மூலம் வெளிப்படுத்தப்படாது - உருவாக்கிய பின் இணைய UI இலிருந்து அவற்றைச் சேர்க்கவும்."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "行程时间和附件通过 google.com 同步，但不会通过 Google Calendar API 公开 - 创建后从 Web UI 添加它们。"
          }
        },
        "id": {
          "stringUnit": {
            "state": "new",
            "value": "Travel Time and attachments sync through google.com but aren't exposed through the Google Calendar API — add them from the web UI after creating."
