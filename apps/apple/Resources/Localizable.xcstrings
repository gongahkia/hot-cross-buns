    "macOS rejected %@ reminder%@. Check System Settings → Notifications → Hot Cross Buns, or the app logs for the underlying error.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "macOS rejected %1$@ reminder%2$@. Check System Settings → Notifications → Hot Cross Buns, or the app logs for the underlying error."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "macOS menolak %1$@ peringatan%2$@. Semak Tetapan Sistem → Pemberitahuan → Hot Cross Buns, atau log aplikasi untuk ralat asas."
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "macOS நிராகரித்தது %1$@ நினைவூட்டல்%2$@. சிஸ்டம் செட்டிங்ஸ் → அறிவிப்புகள் → ஹாட் கிராஸ் பன்ஸ் அல்லது ஆப்ஸ் லாக்ஸை அடிப்படை பிழையை சரிபார்க்கவும்."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "macOS 拒绝了 %1$@ 提醒 %2$@。检查系统设置 → 通知 → Hot Cross Buns，或应用程序日志中的潜在错误。"
          }
        },
