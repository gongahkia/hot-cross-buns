    "Disabling will rewrite the cache as plaintext on disk. The passphrase is required so a stolen laptop can't flip this off.": {
      "localizations": {
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Melumpuhkan akan menulis semula cache sebagai plaintext pada cakera. Ungkapan laluan diperlukan supaya komputer riba yang dicuri tidak dapat menghidupkannya."
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "செயலிழக்கச் செய்வது வட்டில் கேச் சாதாரண உரையாக மீண்டும் எழுதும். கடவுச்சொற்றொடர் தேவைப்படுவதால் திருடப்பட்ட மடிக்கணினியால் இதைப் புரட்ட முடியாது."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "禁用会将缓存重写为磁盘上的明文。需要密码短语，因此被盗的笔记本电脑无法关闭此功能。"
          }
        },
        "id": {
          "stringUnit": {
            "state": "new",
            "value": "Disabling will rewrite the cache as plaintext on disk. The passphrase is required so a stolen laptop can't flip this off."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "new",
            "value": "Disabling will rewrite the cache as plaintext on disk. The passphrase is required so a stolen laptop can't flip this off."
          }
        },
        "th": {
          "stringUnit": {
            "state": "new",
            "value": "Disabling will rewrite the cache as plaintext on disk. The passphrase is required so a stolen laptop can't flip this off."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "new",
            "value": "Disabling will rewrite the cache as plaintext on disk. The passphrase is required so a stolen laptop can't flip this off."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "new",
            "value": "Disabling will rewrite the cache as plaintext on disk. The passphrase is required so a stolen laptop can't flip this off."
          }
        },
        "zh-Hant": {
