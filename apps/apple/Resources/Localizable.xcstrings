          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Berlaku untuk %1$@ tugas%2$@. Teg %3$@ setiap tugasan dilangkau secara senyap oleh pengoptimum."
          }
        },
        "ta": {
