    "Saves this event's summary, duration, reminders, attendees, and color as a reusable blueprint in Settings.": {
      "localizations": {
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Menyimpan ringkasan, tempoh, peringatan, peserta dan warna acara ini sebagai pelan tindakan yang boleh digunakan semula dalam Tetapan."
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "இந்த நிகழ்வின் சுருக்கம், காலம், நினைவூட்டல்கள், பங்கேற்பாளர்கள் மற்றும் வண்ணத்தை அமைப்புகளில் மீண்டும் பயன்படுத்தக்கூடிய வரைபடமாகச் சேமிக்கிறது."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
