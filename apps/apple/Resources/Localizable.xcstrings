    "Settings always stays visible so you can re-enable hidden tabs. Keyboard shortcuts for a hidden tab are ignored until it's re-enabled.": {
      "localizations": {
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Tetapan sentiasa kekal kelihatan supaya anda boleh mendayakan semula tab tersembunyi. Pintasan papan kekunci untuk tab tersembunyi diabaikan sehingga ia didayakan semula."
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "அமைப்புகள் எப்போதும் காணக்கூடியதாக இருக்கும், எனவே மறைக்கப்பட்ட தாவல்களை மீண்டும் இயக்கலாம். மறைக்கப்பட்ட தாவலுக்கான விசைப்பலகை குறுக்குவழிகள் மீண்டும் இயக்கப்படும் வரை புறக்கணிக்கப்படும்."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "设置始终保持可见，因此您可以重新启用隐藏的选项卡。隐藏选项卡的键盘快捷键将被忽略，直到重新启用为止。"
          }
        },
        "id": {
          "stringUnit": {
            "state": "new",
            "value": "Settings always stays visible so you can re-enable hidden tabs. Keyboard shortcuts for a hidden tab are ignored until it's re-enabled."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "new",
            "value": "Settings always stays visible so you can re-enable hidden tabs. Keyboard shortcuts for a hidden tab are ignored until it's re-enabled."
          }
        },
        "th": {
          "stringUnit": {
            "state": "new",
            "value": "Settings always stays visible so you can re-enable hidden tabs. Keyboard shortcuts for a hidden tab are ignored until it's re-enabled."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "new",
            "value": "Settings always stays visible so you can re-enable hidden tabs. Keyboard shortcuts for a hidden tab are ignored until it's re-enabled."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "new",
            "value": "Settings always stays visible so you can re-enable hidden tabs. Keyboard shortcuts for a hidden tab are ignored until it's re-enabled."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "new",
