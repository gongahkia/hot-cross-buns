    "Preview DMG blocked by macOS? Open Hot Cross Buns once, then go to System Settings > Privacy & Security and click Open Anyway.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Preview DMG blocked by macOS? Open Hot Cross Buns once, then go to System Settings > Privacy & Security and click Open Anyway."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Pratonton DMG disekat oleh macOS? Buka Hot Cross Buns sekali, kemudian pergi ke Tetapan Sistem > Privasi & Keselamatan dan klik Buka Bagaimanapun."
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "MacOS ஆல் DMG தடுக்கப்பட்டதா? Hot Cross Buns ஐ ஒருமுறை திறந்து, பின்னர் கணினி அமைப்புகள் > தனியுரிமை & பாதுகாப்பு என்பதற்குச் சென்று எப்படியும் திற என்பதைக் கிளிக் செய்யவும்."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "预览 DMG 被 macOS 阻止？打开 Hot Cross Buns 一次，然后转到系统设置 > 隐私和安全，然后单击仍然打开。"
          }
        },
        "id": {
          "stringUnit": {
            "state": "new",
            "value": "Preview DMG blocked by macOS? Open Hot Cross Buns once, then go to System Settings > Privacy & Security and click Open Anyway."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "new",
            "value": "Preview DMG blocked by macOS? Open Hot Cross Buns once, then go to System Settings > Privacy & Security and click Open Anyway."
