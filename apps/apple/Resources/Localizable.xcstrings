    "Accepts today / tonight / tomorrow aliases, next-weekday phrases, relative offsets, and end-of-period shortcuts.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Accepts today / tonight / tomorrow aliases, next-weekday phrases, relative offsets, and end-of-period shortcuts."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Menerima alias hari ini / malam ini / esok, frasa hari minggu depan, offset relatif dan pintasan akhir tempoh."
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "இன்று / இன்றிரவு / நாளை மாற்றுப்பெயர்கள், அடுத்த வார சொற்றொடர்கள், தொடர்புடைய ஆஃப்செட்டுகள் மற்றும் காலத்தின் இறுதிக் குறுக்குவழிகளை ஏற்கும்."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "接受今天/今晚/明天别名、下周短语、相对偏移量和期末快捷方式。"
          }
        },
        "id": {
          "stringUnit": {
            "state": "new",
            "value": "Accepts today / tonight / tomorrow aliases, next-weekday phrases, relative offsets, and end-of-period shortcuts."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "new",
            "value": "Accepts today / tonight / tomorrow aliases, next-weekday phrases, relative offsets, and end-of-period shortcuts."
          }
        },
        "th": {
          "stringUnit": {
            "state": "new",
            "value": "Accepts today / tonight / tomorrow aliases, next-weekday phrases, relative offsets, and end-of-period shortcuts."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "new",
            "value": "Accepts today / tonight / tomorrow aliases, next-weekday phrases, relative offsets, and end-of-period shortcuts."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "new",
            "value": "Accepts today / tonight / tomorrow aliases, next-weekday phrases, relative offsets, and end-of-period shortcuts."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "new",
            "value": "Accepts today / tonight / tomorrow aliases, next-weekday phrases, relative offsets, and end-of-period shortcuts."
          }
        },
        "hi": {
