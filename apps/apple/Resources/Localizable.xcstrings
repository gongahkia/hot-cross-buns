    "Every open task with a due date fires a single notification on this Mac at the chosen time, N days before. Per-task offsets are not stored anywhere — the rule is app-wide.": {
      "localizations": {
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Setiap tugasan terbuka dengan tarikh akhir melancarkan satu pemberitahuan pada Mac ini pada masa yang dipilih, N hari sebelumnya. Offset setiap tugasan tidak disimpan di mana-mana — peraturan adalah di seluruh apl."
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "குறிப்பிட்ட தேதியுடன் கூடிய ஒவ்வொரு திறந்த பணியும், N நாட்களுக்கு முன்பு, தேர்ந்தெடுக்கப்பட்ட நேரத்தில் இந்த Mac இல் ஒரு அறிவிப்பை வெளியிடும். ஒவ்வொரு பணிக்கும் ஆஃப்செட்கள் எங்கும் சேமிக்கப்படாது - விதி பயன்பாடு முழுவதும் உள்ளது."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "每个具有截止日期的未完成任务都会在 N 天前的选定时间在此 Mac 上触发一条通知。每个任务的偏移量不会存储在任何地方 - 该规则是应用程序范围内的。"
          }
        },
        "id": {
          "stringUnit": {
            "state": "new",
            "value": "Every open task with a due date fires a single notification on this Mac at the chosen time, N days before. Per-task offsets are not stored anywhere — the rule is app-wide."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "new",
            "value": "Every open task with a due date fires a single notification on this Mac at the chosen time, N days before. Per-task offsets are not stored anywhere — the rule is app-wide."
          }
        },
        "th": {
          "stringUnit": {
            "state": "new",
            "value": "Every open task with a due date fires a single notification on this Mac at the chosen time, N days before. Per-task offsets are not stored anywhere — the rule is app-wide."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "new",
            "value": "Every open task with a due date fires a single notification on this Mac at the chosen time, N days before. Per-task offsets are not stored anywhere — the rule is app-wide."
          }
        },
        "ko": {
