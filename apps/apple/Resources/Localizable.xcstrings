    "Stuck sync? Use Sync menu > Force Full Resync or open Sync Issues to inspect conflicts, invalid payloads, and deferred reminders.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Stuck sync? Use Sync menu > Force Full Resync or open Sync Issues to inspect conflicts, invalid payloads, and deferred reminders."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Penyegerakan tersekat? Gunakan menu Penyegerakan > Paksa Segerak Semula Penuh atau buka Isu Penyegerakan untuk memeriksa konflik, muatan tidak sah dan peringatan tertunda."
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "ஒத்திசைவு சிக்கியுள்ளதா? முரண்பாடுகள், தவறான பேலோடுகள் மற்றும் ஒத்திவைக்கப்பட்ட நினைவூட்டல்களை ஆய்வு செய்ய ஒத்திசைவு மெனு > ஃபோர்ஸ் ஃபுல் ரிசின்க் அல்லது ஓபன் ஒத்திசைவுச் சிக்கல்களைப் பயன்படுத்தவும்."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "同步卡住了？使用“同步”菜单 >“强制完全重新同步”或打开“同步问题”来检查冲突、无效负载和延迟提醒。"
          }
        },
        "id": {
          "stringUnit": {
            "state": "new",
            "value": "Stuck sync? Use Sync menu > Force Full Resync or open Sync Issues to inspect conflicts, invalid payloads, and deferred reminders."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "new",
            "value": "Stuck sync? Use Sync menu > Force Full Resync or open Sync Issues to inspect conflicts, invalid payloads, and deferred reminders."
