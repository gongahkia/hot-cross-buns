    "When the query field is non-empty, the fields below are ignored. Invalid queries match nothing — your tasks aren't modified.": {
      "localizations": {
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Apabila medan pertanyaan tidak kosong, medan di bawah diabaikan. Pertanyaan tidak sah tidak sepadan — tugas anda tidak diubah suai."
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "வினவல் புலம் காலியாக இல்லாதபோது, ​​கீழே உள்ள புலங்கள் புறக்கணிக்கப்படும். தவறான வினவல்கள் எதுவும் பொருந்தவில்லை - உங்கள் பணிகள் மாற்றப்படவில்லை."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "当查询字段非空时，下面的字段将被忽略。无效查询不匹配任何内容 - 您的任务不会被修改。"
          }
        },
        "id": {
          "stringUnit": {
            "state": "new",
            "value": "When the query field is non-empty, the fields below are ignored. Invalid queries match nothing — your tasks aren't modified."
          }
        },
