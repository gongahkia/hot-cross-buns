            "value": "Off: the popover starts compact and hides optional fields behind \"More\". On: the popover opens detailed — matches Apple Calendar's inline expansion."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "new",
            "value": "Off: the popover starts compact and hides optional fields behind \"More\". On: the popover opens detailed — matches Apple Calendar's inline expansion."
          }
