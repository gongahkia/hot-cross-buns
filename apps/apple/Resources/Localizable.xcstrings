    "Appears as a section in the menu-bar popover with a match count and a short preview.": {
      "localizations": {
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Muncul sebagai bahagian dalam popover bar menu dengan kiraan padanan dan pratonton pendek."
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "மேட்ச் எண்ணிக்கை மற்றும் குறுகிய முன்னோட்டத்துடன் மெனு-பார் பாப்ஓவரில் ஒரு பிரிவாகத் தோன்றும்."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
