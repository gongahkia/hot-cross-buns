    "Off: the popover starts compact and hides optional fields behind \"More\". On: the popover opens detailed — matches Apple Calendar's inline expansion.": {
      "localizations": {
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Mati: popover mula padat dan menyembunyikan medan pilihan di belakang \"Lagi\". Hidupkan: popover dibuka secara terperinci — sepadan dengan pengembangan sebaris Kalendar Apple."
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "ஆஃப்: பாப்ஓவர் கச்சிதமாகத் தொடங்கி, \"மேலும்\" என்பதற்குப் பின்னால் விருப்பப் புலங்களை மறைக்கிறது. ஆன்: பாப்ஓவர் விரிவாகத் திறக்கிறது — Apple Calendar இன் இன்லைன் விரிவாக்கத்துடன் பொருந்துகிறது."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "关闭：弹出窗口开始紧凑，并将可选字段隐藏在“更多”后面。开：弹出窗口详细打开 — 与 Apple 日历的内联扩展相匹配。"
          }
        },
        "id": {
          "stringUnit": {
            "state": "new",
            "value": "Off: the popover starts compact and hides optional fields behind \"More\". On: the popover opens detailed — matches Apple Calendar's inline expansion."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "new",
            "value": "Off: the popover starts compact and hides optional fields behind \"More\". On: the popover opens detailed — matches Apple Calendar's inline expansion."
          }
