    "Drag an existing event to reschedule it while preserving duration and 15-minute snapping.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Drag an existing event to reschedule it while preserving duration and 15-minute snapping."
