    "Updates send If-Match etags so conflicts can be reviewed instead of silently overwritten.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Updates send If-Match etags so conflicts can be reviewed instead of silently overwritten."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Kemas kini menghantar etags If-Match supaya konflik boleh disemak dan bukannya ditimpa secara senyap."
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "புதுப்பிப்புகள் If-Match etagகளை அனுப்புகின்றன, எனவே முரண்பாடுகளை அமைதியாக மேலெழுதுவதற்குப் பதிலாக மதிப்பாய்வு செய்யலாம்."
          }
        },
