        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Kord pemimpin menggunakan semula sistem arahan yang sama seperti menu dan pintasan."
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "லீடர் கோர்ட்கள் மெனுக்கள் மற்றும் குறுக்குவழிகள் போன்ற அதே கட்டளை அமைப்பை மீண்டும் பயன்படுத்துகின்றன."
