    "Override the global font + size for specific surfaces. Settings persist locally and never touch Google data. Unset surfaces inherit the global Appearance values above.": {
      "localizations": {
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Gantikan fon global + saiz untuk permukaan tertentu. Tetapan berterusan secara setempat dan jangan sekali-kali menyentuh data Google. Permukaan yang tidak ditetapkan mewarisi nilai Rupa global di atas."
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "குறிப்பிட்ட மேற்பரப்புகளுக்கான உலகளாவிய எழுத்துரு + அளவை மேலெழுதவும். அமைப்புகள் உள்ளூரில் தொடர்ந்து இருக்கும் மற்றும் Google தரவைத் தொடவே இல்லை. அமைக்கப்படாத மேற்பரப்புகள் மேலே உள்ள உலகளாவிய தோற்ற மதிப்புகளைப் பெறுகின்றன."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "覆盖特定表面的全局字体+大小。设置保留在本地，并且永远不会触及 Google 数据。未设置的曲面继承上面的全局外观值。"
          }
        },
        "id": {
          "stringUnit": {
            "state": "new",
            "value": "Override the global font + size for specific surfaces. Settings persist locally and never touch Google data. Unset surfaces inherit the global Appearance values above."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "new",
            "value": "Override the global font + size for specific surfaces. Settings persist locally and never touch Google data. Unset surfaces inherit the global Appearance values above."
