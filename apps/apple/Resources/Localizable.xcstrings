    "Drag a task from the drawer onto a day column to create a 60-minute event back-linked to the task.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Drag a task from the drawer onto a day column to create a 60-minute event back-linked to the task."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Seret tugasan daripada laci ke lajur hari untuk mencipta acara 60 minit yang dipautkan kembali kepada tugasan itu."
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "பணியுடன் மீண்டும் இணைக்கப்பட்ட 60 நிமிட நிகழ்வை உருவாக்க, டிராயரில் இருந்து ஒரு நாள் நெடுவரிசையில் ஒரு பணியை இழுக்கவும்."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "将任务从抽屉拖到日期列上，以创建反向链接到该任务的 60 分钟事件。"
          }
        },
