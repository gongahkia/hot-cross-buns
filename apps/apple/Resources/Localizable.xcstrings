    "Task quick-add parses due-date aliases and list hints, eg. 'email rent receipt tmr #personal'.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Task quick-add parses due-date aliases and list hints, eg. 'email rent receipt tmr #personal'."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Tambah pantas tugasan menghuraikan alias tarikh akhir dan pembayang senarai, cth. 'emel resit sewa tmr #personal'."
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "டாஸ்க் விரைவு-சேர் பாகுபடுத்தும் இறுதி தேதி மாற்றுப்பெயர்கள் மற்றும் பட்டியல் குறிப்புகள், எ.கா. 'மின்னஞ்சல் வாடகை ரசீது டிஎம்ஆர் #தனிப்பட்டம்'."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "任务快速添加解析截止日期别名并列出提示，例如。 “通过电子邮件发送租金收据 tmr #personal”。"
          }
        },
        "id": {
          "stringUnit": {
            "state": "new",
            "value": "Task quick-add parses due-date aliases and list hints, eg. 'email rent receipt tmr #personal'."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "new",
            "value": "Task quick-add parses due-date aliases and list hints, eg. 'email rent receipt tmr #personal'."
          }
        },
