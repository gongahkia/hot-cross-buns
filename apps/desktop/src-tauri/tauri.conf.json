{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Hot Cross Buns",
  "version": "0.1.0",
  "identifier": "com.hotcrossbuns.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "Hot Cross Buns",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600
      },
      {
        "label": "capture",
        "title": "Quick Capture",
        "url": "/capture",
        "width": 520,
        "height": 200,
        "minWidth": 400,
        "minHeight": 150,
        "visible": false,
        "decorations": false,
        "alwaysOnTop": true,
        "center": true,
        "skipTaskbar": true,
        "resizable": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self'; img-src 'self' asset: https://asset.localhost; connect-src 'self' https: http://localhost:*"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
