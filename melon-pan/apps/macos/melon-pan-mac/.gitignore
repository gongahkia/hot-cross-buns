# Generated by xcodegen — regenerate from project.yml.
*.xcodeproj/
*.xcworkspace/

# Output of scripts/build-rust-staticlib.sh — universal libmelon_pan_mac_ffi.a
# plus the copied bridging header. Reproduced from cargo + repo state on
# every build; no need to track.
MelonPan/Build/

# Output of scripts/package-dmg.sh — unsigned MelonPan-X.Y.Z.dmg ready
# for hand-signing + notarization.
dist/

# Xcode user data + DerivedData if it gets dropped here by accident.
xcuserdata/
DerivedData/
*.xcuserstate
